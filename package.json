{
  "name": "@emptist/piano",
  "version": "0.1.0",
  "description": "Piano - AI-driven autonomous development system extension with continuous work engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "start:daemon": "node dist/daemon/index.js"
  },
  "dependencies": {
    "@emptist/nezha": "^0.1.0",
    "@emptist/nupi": "^0.1.0",
    "@mariozechner/pi-coding-agent": "^0.63.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "tsx": "^4.21.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "piano",
    "opencode",
    "pi",
    "ai",
    "autonomous",
    "continuous-work",
    "nezha-extension"
  ],
  "author": "emptist",
  "license": "MIT"
}
