{
  "name": "@nezha/piano",
  "version": "0.5.0",
  "description": "Piano = Thinking Router + NuPI + OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "piano": "./bin/piano"
  },
  "keywords": [
    "nezha",
    "nupi",
    "opencode",
    "ai",
    "task-routing",
    "autonomous"
  ],
  "author": "emptist",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@mariozechner/pi-coding-agent": "^0.67.2",
    "@nezha/nupi": "^0.5.0",
    "@opencode-ai/sdk": "^1.14.19",
    "@sinclair/typebox": "^0.32.0",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@types/ajv": "^0.0.5",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/replace-hash.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "predev": "npm run build",
    "dev": "rm -rf $(npm root -g)/@nezha/piano; npm link; echo === STATUS ===; echo Local:; grep GIT_HASH dist/src/extension.js; echo Global:; grep GIT_HASH $(npm root -g)/@nezha/piano/dist/src/extension.js",
    "prestatus": "test -d dist || npm run build",
    "status": "echo === STATUS ===; echo Local:; grep GIT_HASH dist/src/extension.js; echo Global:; grep GIT_HASH $(npm root -g)/@nezha/piano/dist/src/extension.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emptist/nezha.git",
    "directory": "piano"
  },
  "bugs": {
    "url": "https://github.com/emptist/nezha/issues"
  }
}
