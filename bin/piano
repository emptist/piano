#!/bin/bash
# Piano Launcher
#
# Usage:
#   piano              Delegate to Nezha/OpenCode (default, no AI needed)
#   piano -i           Start Pi interactive mode (with 3B model)
#   piano --interactive Same as -i
#   piano --print      Non-interactive delegation (alias for default)
#   piano nupi         Start NuPI mode
#   piano --help       Show help

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

PIANO_EXT="$SCRIPT_DIR/../extensions/piano-tools.ts"
NUPI_EXT="$HOME/.pi/agent/extensions/nupi-tools.ts"

show_help() {
    cat <<EOF
Piano Launcher

Usage:
    piano              Delegate work to Nezha/OpenCode (default)
    piano -i           Start Pi interactive mode
    piano --print      Non-interactive delegation (same as default)
    piano nupi         Start NuPI mode
    piano --help       Show this help

Environment:
    PIANO_DELEGATE_ALL Set to 'false' to use 3B model instead of delegating
EOF
}

run_piano_print() {
    echo "[Piano] Delegating to Nezha/OpenCode..."

    local NEZHA_BIN
    NEZHA_BIN="$(command -v nezha 2>/dev/null || true)"
    if [ -z "$NEZHA_BIN" ] || [ ! -f "$NEZHA_BIN" ]; then
        for c in /opt/homebrew/bin/nezha /usr/local/bin/nezha; do
            [ -f "$c" ] && NEZHA_BIN="$c" && break
        done
    fi

    if [ -z "$NEZHA_BIN" ] || [ ! -f "$NEZHA_BIN" ]; then
        echo "[Piano] Error: nezha not found." >&2
        return 1
    fi

    echo "[Piano] Using nezha: $NEZHA_BIN"

    echo ""
    echo "=== PENDING TASKS ==="
    node "$NEZHA_BIN" tasks --status PENDING 2>&1 || true

    echo ""
    echo "=== TRIGGERING IMPROVEMENT CYCLE ==="
    node "$NEZHA_BIN" continuous-improvement 2>&1 || true

    echo ""
    echo "[PianO] Done. Tasks queued for OpenCode."
}

run_piano_interactive() {
    local PI_ARGS=("-i" "--no-extensions" "-e" "$PIANO_EXT")

    if [ -t 1 ]; then
        exec pi "${PI_ARGS[@]}" "$@"
    else
        echo "[Piano] No TTY on stdout. Trying pseudo-TTY..." >&2
        if command -v script &>/dev/null; then
            exec script -q /dev/null pi "${PI_ARGS[@]}" "$@"
        else
            echo "[Piano] No TTY and no 'script' command available." >&2
            echo "[Piano] Use: piano --print  (no TTY needed)" >&2
            return 1
        fi
    fi
}

run_nupi() {
    echo "[Piano] Starting NuPI mode..."
    exec pi --no-extensions -e "$NUPI_EXT" "$@"
}

case "${1:-}" in
    -i|--interactive)
        shift
        run_piano_interactive "$@"
        ;;
    --print|-p|"")
        shift
        run_piano_print "$@"
        ;;
    nupi)
        shift
        run_nupi "$@"
        ;;
    -h|--help)
        show_help
        ;;
    *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
esac
