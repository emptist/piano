#!/bin/bash
# Piano Launcher
#
# Usage:
#   piano              Start Piano mode (Pi + extensions)
#   piano --print      Non-interactive delegation only (no Pi)
#   piano nupi         Start NuPI mode
#   piano --help       Show help

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

PIANO_EXT="$SCRIPT_DIR/../extensions/piano-tools.ts"
PIANO_AUTOWORK="$SCRIPT_DIR/../extensions/piano-autowork.ts"
NUPI_EXT="$HOME/.pi/agent/extensions/nupi-tools.ts"

show_help() {
    cat <<EOF
Piano Launcher

Usage:
    piano              Start Piano (Pi interactive mode)
    piano --print      Delegate to Nezha only (no AI)
    piano nupi         Start NuPI mode
    piano --help       Show this help
EOF
}

run_piano() {
    local PI_ARGS=("--no-extensions" "-e" "$PIANO_EXT" "-e" "$PIANO_AUTOWORK")

    if [ -t 1 ]; then
        exec pi "${PI_ARGS[@]}" "$@"
    else
        echo "[Piano] No TTY on stdout. Trying pseudo-TTY..." >&2
        if command -v script &>/dev/null; then
            exec script -q /dev/null pi "${PI_ARGS[@]}" "$@"
        else
            echo "[Piano] No TTY and no 'script' command." >&2
            echo "[Piano] Use: piano --print  (no TTY needed)" >&2
            return 1
        fi
    fi
}

run_piano_print() {
    local API="http://127.0.0.1:5999"

    echo "[Piano] Delegating to Nezha/OpenCode via API..."

    if ! curl -s --max-time 3 "$API/health" >/dev/null 2>&1; then
        echo "[Piano] Error: Nezha API not responding at $API" >&2
        echo "[Piano] Run 'nezha start' first, then try again." >&2
        return 1
    fi

    echo ""
    echo "=== PENDING TASKS (sample) ==="
    curl -s --max-time 5 "$API/tasks?status=PENDING&limit=5" | python3 -c "
import sys,json
try:
    data=json.load(sys.stdin)
    tasks=data.get('rows', data)
    if not tasks: print('  (no pending tasks)'); sys.exit()
    for t in tasks[:5]: print(f\"  [{t.get('priority','?')}] {t.get('title','?')[:60]}\")
    if len(tasks)>5: print(f'  ... and {len(tasks)-5} more')
except Exception as e: print(f'  (error: {e})')
" 2>&1

    echo ""
    echo "=== TRIGGERING IMPROVEMENT CYCLE ==="
    local RESULT
    RESULT=$(curl -s --max-time 5 -X POST "$API/tasks" \
        -H 'Content-Type: application/json' \
        -d '{"title":"Continuous Improvement Cycle","description":"Review codebase, find issues, create improvement tasks. PDCA.","priority":10,"category":"bugfix"}' \
        2>&1)

    if echo "$RESULT" | grep -q '"id"'; then
        local TASK_ID
        TASK_ID=$(echo "$RESULT" | python3 -c "import sys,json;d=json.load(sys.stdin);print(d.get('id', d.get('id', '?'))[:8])")
        echo "[Piano] Done. Task $TASK_ID... queued for OpenCode."
    else
        echo "[Piano] Warning: $RESULT"
    fi

    echo ""
    echo "[Piano] Done."
}

run_nupi() {
    echo "[Piano] Starting NuPI mode..."
    exec pi --no-extensions -e "$NUPI_EXT" "$@"
}

case "${1:-}" in
    ""|-p|--piano)
        shift
        run_piano "$@"
        ;;
    --print)
        shift
        run_piano_print "$@"
        ;;
    nupi)
        shift
        run_nupi "$@"
        ;;
    -h|--help)
        show_help
        ;;
    *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
esac
