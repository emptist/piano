#!/bin/bash
# Piano Launcher
#
# Usage:
#   piano              Start Piano mode (Pi + extensions)
#   piano --print      Non-interactive delegation only (no Pi)
#   piano nupi         Start NuPI mode
#   piano --help       Show help

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

PIANO_EXT="$SCRIPT_DIR/../extensions/piano-tools.ts"
PIANO_AUTOWORK="$SCRIPT_DIR/../extensions/piano-autowork.ts"

# NuPI extensions: use npm package (2026-04-14)
NUPI_TOOLS="$SCRIPT_DIR/../node_modules/@nezha/nupi/extensions/nupi-tools.ts"
NUPI_AUTOWORK="$SCRIPT_DIR/../node_modules/@nezha/nupi/extensions/nupi-autowork.ts"

show_help() {
    cat <<EOF
Piano Launcher

Usage:
    piano              Start Piano (Pi interactive mode)
    piano --print      Delegate to Nezha only (no AI)
    piano nupi         Start NuPI mode
    piano --help       Show this help
EOF
}

run_piano() {
    # NuPI extensions: use original from nupi project (not copied)
    local PI_ARGS=("--no-extensions" 
        "-e" "$PIANO_EXT" 
        "-e" "$PIANO_AUTOWORK"
        "-e" "$NUPI_TOOLS"
        "-e" "$NUPI_AUTOWORK")

    if [ -t 1 ]; then
        exec pi "${PI_ARGS[@]}" "$@"
    else
        echo "[Piano] No TTY on stdout. Trying pseudo-TTY..." >&2
        if command -v script &>/dev/null; then
            exec script -q /dev/null pi "${PI_ARGS[@]}" "$@"
        else
            echo "[Piano] No TTY and no 'script' command." >&2
            echo "[Piano] Use: piano --print  (no TTY needed)" >&2
            return 1
        fi
    fi
}

run_piano_print() {
    # Use CLI instead of HTTP API (2026-04-14)
    echo "[Piano] Checking pending tasks via CLI..."

    echo ""
    echo "=== PENDING TASKS (sample) ==="
    nezha tasks --status PENDING --limit 5 2>&1 | head -10

    echo ""
    echo "=== CREATING IMPROVEMENT TASK ==="
    RESULT=$(nezha task-add "Continuous Improvement Cycle" "Review codebase, find issues, create improvement tasks. PDCA." --priority 10 2>&1)
    echo "$RESULT"

    echo ""
    echo "[Piano] Done."
}

run_nupi() {
    echo "[Piano] Starting NuPI mode..."
    exec pi --no-extensions -e "$NUPI_TOOLS" "$@"
}

case "${1:-}" in
    ""|-p|--piano)
        shift
        run_piano "$@"
        ;;
    --print)
        shift
        run_piano_print "$@"
        ;;
    nupi)
        shift
        run_nupi "$@"
        ;;
    -h|--help)
        show_help
        ;;
    *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
esac
